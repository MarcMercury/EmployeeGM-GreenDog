# =====================================================
# Supabase Configuration (REQUIRED)
# Get these from: Supabase Dashboard → Settings → API
# =====================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# =====================================================
# Optional: Service Role Key (for admin operations)
# =====================================================
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================
# Vercel (auto-populated by Vercel)
# =====================================================
# VERCEL_PROJECT_ID=your-vercel-project-id

# =====================================================
# IMPORTANT: Add these to Vercel Dashboard!
# Project Settings → Environment Variables
# Add both SUPABASE_URL and SUPABASE_KEY
# =====================================================

# =====================================================
# OpenAI Configuration (for AI features)
# Get these from: platform.openai.com/api-keys
# =====================================================
OPENAI_API_KEY=sk-proj-your-api-key
OPENAI_ADMIN_KEY=sk-admin-your-admin-key

# =====================================================
# Slack Configuration (for team notifications)
# Get these from: api.slack.com/apps → Your App
# =====================================================
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# =====================================================
# Email Configuration (for invitations and notifications)
# Get API key from: resend.com/api-keys
# =====================================================
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=Green Dog Veterinary <noreply@greendog.vet>

# =====================================================
# Application URL (REQUIRED for production)
# Used for generating email links and redirects
# =====================================================
APP_URL=https://employeegm.greendog.vet

# =====================================================
# Google APIs (Calendar, Drive, Business, GA4, Maps)
# Service Account: console.cloud.google.com → IAM → Service Accounts
# Maps: console.cloud.google.com/apis/library/maps-backend.googleapis.com
# GA4: analytics.google.com → Admin → Data Streams
# =====================================================
GOOGLE_SERVICE_ACCOUNT_JSON={"client_email":"...","private_key":"..."}
GOOGLE_MAPS_API_KEY=your-maps-server-key
GOOGLE_MAPS_PUBLIC_KEY=your-maps-client-key
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your-measurement-protocol-secret

# =====================================================
# Cal.com (Scheduling)
# Get from: cal.com → Settings → Developer → API Keys
# =====================================================
CALCOM_API_KEY=cal_live_your-api-key
CALCOM_BASE_URL=https://api.cal.com/v1

# =====================================================
# Cronitor (Cron Job Monitoring)
# Get from: cronitor.io → Settings → API Keys
# =====================================================
CRONITOR_API_KEY=your-cronitor-api-key

# =====================================================
# Clockify (Time Tracking)
# Get from: clockify.me → Profile → API → Generate Key
# =====================================================
CLOCKIFY_API_KEY=your-clockify-api-key

# =====================================================
# SendGrid (Transactional Email)
# Get from: app.sendgrid.com/settings/api_keys
# =====================================================
SENDGRID_API_KEY=SG.your-sendgrid-key

# =====================================================
# OneSignal (Push Notifications)
# Get from: onesignal.com → Settings → Keys & IDs
# =====================================================
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-rest-api-key

# =====================================================
# Google Gemini (AI)
# Get from: ai.google.dev → Get API Key
# =====================================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# =====================================================
# Pinecone (Vector Database)
# Get from: app.pinecone.io → API Keys
# =====================================================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=employee-gm-knowledge

# =====================================================
# AssemblyAI (Transcription)
# Get from: assemblyai.com → Dashboard → API Key
# =====================================================
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# =====================================================
# PandaDoc (e-Signatures)
# Get from: app.pandadoc.com → Developer Dashboard → API Keys
# =====================================================
PANDADOC_API_KEY=your-pandadoc-api-key

# =====================================================
# Mixpanel (Product Analytics)
# Get from: mixpanel.com → Settings → Project Settings
# =====================================================
MIXPANEL_TOKEN=your-mixpanel-project-token

# =====================================================
# Mailchimp (Email Campaigns)
# Get from: mailchimp.com → Account → Extras → API Keys
# =====================================================
MAILCHIMP_API_KEY=your-key-us21

# =====================================================
# HubSpot (CRM)
# Get from: developers.hubspot.com → Your App → Auth
# =====================================================
HUBSPOT_ACCESS_TOKEN=pat-your-hubspot-token

# =====================================================
# Yelp Fusion (Reviews & Search)
# Get from: yelp.com/developers/v3/manage_app
# =====================================================
YELP_API_KEY=your-yelp-api-key

# =====================================================
# Meta / Facebook (Marketing)
# Get from: developers.facebook.com → Your App → Settings
# =====================================================
META_PAGE_ACCESS_TOKEN=your-page-access-token
META_PAGE_ID=your-page-id

# =====================================================
# Eventbrite (Event Ticketing)
# Get from: eventbrite.com → Account → App Management
# =====================================================
EVENTBRITE_TOKEN=your-eventbrite-private-token
EVENTBRITE_ORGANIZATION_ID=your-org-id

# =====================================================
# Plaid (Bank Connections)
# Get from: dashboard.plaid.com → Keys
# =====================================================
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# =====================================================
# Metabase (Embedded BI)
# Self-hosted: docker run -p 3001:3000 metabase/metabase
# =====================================================
METABASE_URL=http://localhost:3001
METABASE_SECRET_KEY=your-metabase-embedding-secret
METABASE_USERNAME=admin@greendog.vet
METABASE_PASSWORD=your-password

# =====================================================
# VetCove (Veterinary Supplies)
# Contact VetCove for API access
# =====================================================
VETCOVE_API_KEY=your-vetcove-key
